{
  "schema_version": "1.0.0",
  "schema_name": "demographics",
  "description": "人口统计维度标签体系（Layer 1）",
  "dimensions": [
    {
      "id": "age",
      "name": "年龄",
      "description": "年龄段划分",
      "type": "single_select",
      "options": [
        "0-12岁",
        "13-17岁",
        "18-24岁",
        "25-34岁",
        "35-44岁",
        "45-54岁",
        "55-64岁",
        "65-74岁",
        "75岁及以上"
      ]
    },
    {
      "id": "gender",
      "name": "性别",
      "description": "性别认同",
      "type": "single_select",
      "options": [
        "男",
        "女",
        "非二元/其他",
        "不愿透露"
      ]
    },
    {
      "id": "city",
      "name": "现居城市/区域",
      "description": "城市层级划分",
      "type": "single_select",
      "options": [
        "一线城市",
        "新一线城市",
        "二线城市",
        "三线城市",
        "四线城市",
        "五线城市",
        "县城",
        "乡镇",
        "农村",
        "海外"
      ]
    },
    {
      "id": "income",
      "name": "个人年收入",
      "description": "个人年收入档位",
      "type": "single_select",
      "options": [
        "无收入",
        "3万元以下",
        "3-8万元",
        "8-15万元",
        "15-30万元",
        "30-50万元",
        "50-100万元",
        "100万元以上"
      ]
    },
    {
      "id": "occupation",
      "name": "职业",
      "description": "当前从事的职业类型",
      "type": "single_select",
      "options": [
        "学生",
        "企业职员",
        "企业管理者",
        "公务员/事业单位人员",
        "自由职业者",
        "个体经营者/创业者",
        "专业人士（医生/律师/教师等）",
        "蓝领工人",
        "服务业从业者",
        "农林牧渔从业者",
        "军人",
        "退休人员",
        "无业/待业",
        "灵活用工/零工经济从业者",
        "主播/UP主/内容创作者",
        "数字游民",
        "其他"
      ]
    },
    {
      "id": "education",
      "name": "教育程度",
      "description": "最高学历水平",
      "type": "single_select",
      "options": [
        "初中及以下",
        "高中/中专",
        "大专",
        "本科",
        "硕士",
        "博士",
        "成人教育/非全日制",
        "职业培训/技能认证"
      ]
    },
    {
      "id": "marital_status",
      "name": "婚姻状况",
      "description": "当前婚姻状态",
      "type": "single_select",
      "options": [
        "未婚",
        "已婚无子女",
        "已婚有子女",
        "离异",
        "丧偶"
      ]
    },
    {
      "id": "living_type",
      "name": "居住形态",
      "description": "当前居住类型与状态",
      "type": "single_select",
      "options": [
        "自有住房",
        "租房",
        "合租-主卧独卫",
        "合租-次卧/隔断",
        "单身公寓/长租公寓",
        "与父母/亲属同住",
        "夫妻小家庭",
        "多代同堂",
        "单位/企业宿舍",
        "房车/游牧居住",
        "其他"
      ]
    }
  ]
}
