{
  "schema_version": "1.0.0",
  "schema_name": "behaviors",
  "description": "行为维度标签体系（Layer 2）",
  "dimensions": [
    {
      "id": "price_sensitivity",
      "name": "价格敏感度",
      "description": "对价格变化的敏感程度及表现",
      "type": "single_select",
      "options": [
        "比价工具用户（慢慢买/什么值得买）",
        "历史价格查询习惯",
        "保价/补差维权者",
        "不在乎价格波动"
      ]
    },
    {
      "id": "purchase_channels",
      "name": "购买渠道偏好",
      "description": "偏好的购物渠道类型",
      "type": "multi_select",
      "options": [
        "货架电商（淘宝/天猫/京东/拼多多）",
        "内容电商（抖音/快手/小红书/视频号）",
        "私域电商（品牌小程序/社群/个人号/快团团）",
        "即时零售（美团闪购/饿了么/京东到家）",
        "社区团购（多多买菜/美团优选）",
        "二手/闲置（闲鱼/转转/爱回收）",
        "代购/海淘/跨境购",
        "线下-百货/购物中心",
        "线下-品牌专卖店",
        "线下-大型超市/卖场",
        "线下-便利店",
        "线下-奥特莱斯/折扣店",
        "线上与线下均有"
      ]
    },
    {
      "id": "decision_style",
      "name": "决策风格",
      "description": "消费决策时的行为模式",
      "type": "single_select",
      "options": [
        "果断独立",
        "犹豫反复",
        "依赖他人建议/从众"
      ]
    },
    {
      "id": "brand_loyalty",
      "name": "品牌忠诚度",
      "description": "对品牌的忠诚程度",
      "type": "single_select",
      "options": [
        "单一品牌深度忠诚",
        "2-3个品牌间选择",
        "多品牌游走（无固定）",
        "完全无品牌偏好（只看产品/价格）"
      ]
    },
    {
      "id": "information_source",
      "name": "信息来源",
      "description": "获取消费信息的主要渠道",
      "type": "multi_select",
      "options": [
        "朋友/家人推荐",
        "社交媒体/朋友圈",
        "短视频/直播平台",
        "搜索引擎",
        "电商平台搜索/推荐",
        "KOL/达人测评",
        "线下广告/门店",
        "电视/广播/户外广告",
        "品牌邮件/短信",
        "AI问答/智能推荐"
      ]
    }
  ]
}
