{
  "基准场景": {
    "label": "高/中/经济三档产品份额预测",
    "rule": "logit",
    "include_none": true,
    "scenarios": [
      {
        "name": "高端品牌A",
        "price": 6999,
        "capacity": "16套",
        "installation": "嵌入式",
        "features": "智能互联",
        "brand": "品牌A",
        "energy": "一级"
      },
      {
        "name": "中端品牌B",
        "price": 4999,
        "capacity": "13套",
        "installation": "独立式",
        "features": "基础功能",
        "brand": "品牌B",
        "energy": "二级"
      },
      {
        "name": "经济品牌C",
        "price": 2999,
        "capacity": "8套",
        "installation": "台式",
        "features": "基础功能",
        "brand": "品牌C",
        "energy": "三级"
      }
    ],
    "_expected": "中端品牌B 份额最高，三份额之和 ≈ 100%"
  },
  "新品上市": {
    "label": "新品牌打入市场时的份额预测",
    "rule": "first_choice",
    "include_none": false,
    "scenarios": [
      {
        "name": "新品X（16套/智能）",
        "price": 5999,
        "capacity": "16套",
        "installation": "嵌入式",
        "features": "AI智能洗",
        "brand": "新锐品牌",
        "energy": "一级"
      },
      {
        "name": "现有竞品A",
        "price": 6999,
        "capacity": "16套",
        "installation": "嵌入式",
        "features": "智能互联",
        "brand": "品牌A",
        "energy": "一级"
      },
      {
        "name": "现有竞品B",
        "price": 4999,
        "capacity": "13套",
        "installation": "独立式",
        "features": "基础功能",
        "brand": "品牌B",
        "energy": "二级"
      }
    ],
    "_expected": "新品X 在 first_choice 规则下份额最高"
  },
  "不含None选项": {
    "label": "全部消费者强制选择（无'不购买'选项）",
    "rule": "logit",
    "include_none": false,
    "scenarios": [
      { "name": "A款", "price": 3999, "capacity": "8套", "installation": "台式", "features": "基础", "brand": "品牌A", "energy": "二级" },
      { "name": "B款", "price": 5999, "capacity": "13套", "installation": "嵌入式", "features": "智能", "brand": "品牌B", "energy": "一级" }
    ],
    "_expected": "两个产品份额之和 = 100%，无 None 行"
  }
}
