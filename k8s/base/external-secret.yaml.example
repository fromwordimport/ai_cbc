# External Secrets Operator (ESO) Example — ExternalSecret manifest
# =============================================================================
# This is an OPTIONAL example. It is NOT included in kustomization.yaml resources.
# Copy and customize this file for your environment, then apply it separately.
# =============================================================================
#
# Prerequisites:
#   1. External Secrets Operator installed in the cluster:
#      https://external-secrets.io/latest/
#   2. A ClusterSecretStore (or SecretStore) named `aicbc-secret-store` configured
#      to sync from your external secret manager (AWS Secrets Manager, Azure Key
#      Vault, HashiCorp Vault, GCP Secret Manager, etc.).
#
# Usage:
#   1. Copy this file: cp external-secret.yaml.example external-secret.yaml
#   2. Edit the `remoteRef` fields to match your external secret manager keys.
#   3. Apply: kubectl apply -f external-secret.yaml -n <your-namespace>
#
# See also: k8s/CLAUDE.md Secret Management section

apiVersion: external-secrets.io/v1beta1
kind: ExternalSecret
metadata:
  name: aicbc-secrets
  namespace: aicbc-prod
  labels:
    app.kubernetes.io/name: aicbc
    app.kubernetes.io/component: external-secret
spec:
  refreshInterval: "1h"
  secretStoreRef:
    kind: ClusterSecretStore
    name: aicbc-secret-store
  target:
    name: aicbc-secrets
    creationPolicy: Owner
    deletionPolicy: Retain
  data:
    - secretKey: ANTHROPIC_API_KEY
      remoteRef:
        key: aicbc/anthropic-api-key
        property: value
    - secretKey: OPENAI_API_KEY
      remoteRef:
        key: aicbc/openai-api-key
        property: value
    - secretKey: SECRET_KEY
      remoteRef:
        key: aicbc/secret-key
        property: value
    - secretKey: MONGODB_URL
      remoteRef:
        key: aicbc/mongodb-url
        property: value
    - secretKey: REDIS_PASSWORD
      remoteRef:
        key: aicbc/redis-password
        property: value
