# AI_CBC Azure B2ats v2 部署环境变量
# 复制为 .env 并填入真实值

# LLM API 配置
ANTHROPIC_API_KEY=sk-ant-xxxxx
OPENAI_API_KEY=sk-xxxxx
SECRET_KEY=change-me-to-a-secure-secret-in-prod-now

# LLM 模型变量
ANTHROPIC_BASE_URL=https://api.anthropic.com
ANTHROPIC_MODEL_PERSONA=claude-sonnet-4-6
ANTHROPIC_MODEL_SIMULATION=claude-sonnet-4-6
ANTHROPIC_MODEL_AUDIT=claude-haiku-4-5
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o

# LLM 参数
LLM_TEMPERATURE=0.3
LLM_MAX_TOKENS=4096
LLM_TIMEOUT_SECONDS=120
LLM_MAX_RETRIES=3

# 应用配置
ENVIRONMENT=production
DEBUG=false
LOG_LEVEL=INFO
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=1

# 数据库配置
# 单 VM 部署：MONGODB_URL=mongodb://mongo:27017/aicbc
# 多 VM 部署：worker VM 应改为 mongodb://<主 VM IP>:27017/aicbc
MONGODB_URL=mongodb://mongo:27017/aicbc
MONGODB_DATABASE=aicbc
MONGODB_MAX_CONNECTIONS=50
# 单 VM 部署：REDIS_URL=redis://redis:6379/0
# 多 VM 部署：REDIS_URL=redis://:<REDIS_PASSWORD>@<主 VM IP>:6379/0
REDIS_URL=redis://redis:6379/0
# Redis 密码，多 VM 部署时必须在主 VM 与 worker VM 的 .env 中同时设置
# 生成方式：openssl rand -base64 32
REDIS_PASSWORD=change-me-to-a-random-password

# 监控
METRICS_PATH=/metrics
SLOW_REQUEST_THRESHOLD=5.0

# 成本熔断（按需调整）
COST_FUSE_SINGLE_STUDY_CNY=500
COST_FUSE_DAILY_CNY=1000
COST_FUSE_WEEKLY_CNY=5000
COST_FUSE_MONTHLY_CNY=20000
COST_FUSE_DEGRADE_MODEL=claude-haiku-4-5

# 实验设计参数
DEFAULT_N_CHOICE_SETS=12
DEFAULT_N_ALTERNATIVES=3
DEFAULT_SAMPLE_SIZE=150
DEFAULT_D_EFFICIENCY_TARGET=0.85

# 真实性评分阈值
AUTHENTICITY_PASS_THRESHOLD=9
AUTHENTICITY_EXCELLENT_THRESHOLD=12
AUTHENTICITY_MAX_SCORE=14

# 偏见审计配置
BIAS_KS_P_THRESHOLD=0.05
BIAS_CRAMERS_V_THRESHOLD=0.1
BIAS_ENTROPY_THRESHOLD=0.7

# HB 模型资源限制（B2ats v2 1GiB 内存裁剪）
# 限制并行 chain 数量和采样核数，避免 OOM；max_draws 覆盖小样本自动提升。
HB_MAX_CHAINS=2
HB_CORES=1
HB_MAX_DRAWS=1250

# Worker VM 专用：主 VM IP（优先使用内网 IP；跨网络则用公网 IP + NSG 源限制）
AZURE_MAIN_VM_IP=10.0.0.4

# Azure Blob 备份（可选）
# 以下两项仅供 scripts/backup-mongodb-to-azure.sh 使用，不属于 docker compose 栈。
# 需要在 Azure Portal 中创建 Storage Account 和 Blob Container，然后将连接串填入。
# 如果不配置，备份脚本会将 MongoDB 备份保留在本地 /opt/aicbc/backups/mongo。
AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=...;AccountKey=...;EndpointSuffix=core.windows.net
AZURE_BACKUP_CONTAINER=aicbc-backups

# 前端 CORS 来源（Cloudflare Pages / Vercel 等）
# 多个来源用逗号分隔，例如：https://ai-cbc.pages.dev,https://app.aicbc.fromworldimport.com
FRONTEND_ORIGINS=

# 前端登录密码（使用 scripts/generate_password_hash.py 生成 bcrypt 哈希）
FRONTEND_RESEARCHER_PASSWORD_HASH=
FRONTEND_ADMIN_PASSWORD_HASH=
ACCESS_TOKEN_EXPIRE_MINUTES=1440
