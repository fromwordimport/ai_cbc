# AI_CBC 环境变量配置模板
# 复制此文件为 .env 并填入实际值

# ============================================
# LLM API 配置
# ============================================

# Anthropic Claude API (主模型)
ANTHROPIC_API_KEY=sk-ant-xxxxx
ANTHROPIC_BASE_URL=https://api.anthropic.com
ANTHROPIC_MODEL_PERSONA=claude-sonnet-4-6
ANTHROPIC_MODEL_SIMULATION=claude-sonnet-4-6
ANTHROPIC_MODEL_AUDIT=claude-haiku-4-5

# OpenAI API (备用模型)
# 生产环境请使用 `enc:` 前缀的 AES-256-GCM 加密值；明文密钥不得提交到版本控制。
OPENAI_API_KEY=sk-xxxxx
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o

# LLM 调用参数
LLM_TEMPERATURE=0.3
LLM_MAX_TOKENS=4096
LLM_TIMEOUT_SECONDS=120
LLM_MAX_RETRIES=3
LLM_HTTP_MAX_CONNECTIONS=20
LLM_HTTP_MAX_KEEPALIVE=10

# ============================================
# 数据库配置
# ============================================

# MongoDB
# 本地开发使用 mongodb://localhost:27017
# Azure B2ats v2 自托管使用 mongodb://mongo:27017/aicbc
# Render 部署时替换为 MongoDB Atlas 连接串，例如：
# MONGODB_URL=mongodb+srv://user:password@cluster0.xxxxx.mongodb.net/aicbc?retryWrites=true&w=majority
MONGODB_URL=mongodb://localhost:27017
MONGODB_DATABASE=aicbc
MONGODB_MAX_CONNECTIONS=50
MONGODB_MIN_CONNECTIONS=10
MONGODB_MAX_IDLE_TIME_MS=60000
MONGODB_WAIT_QUEUE_TIMEOUT_MS=5000
MONGODB_SERVER_SELECTION_TIMEOUT_MS=5000

# Redis
# 本地开发使用 redis://localhost:6379/0
# Azure B2ats v2 自托管使用 redis://redis:6379/0
# Render 部署时替换为 Upstash Redis URL，例如：
# REDIS_URL=redis://default:password@host.upstash.io:6379
REDIS_URL=redis://localhost:6379/0
REDIS_PASSWORD=

# ============================================
# 应用配置
# ============================================

# 环境: development | staging | production
ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=INFO

# API 服务
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=1

# 密钥（生产环境必须修改）
SECRET_KEY=change-me-to-a-secure-secret-in-prod-now

# ============================================
# 成本熔断配置
# ============================================

# 单次研究成本上限（元）
COST_FUSE_SINGLE_STUDY_CNY=500
# 日成本上限（元）
COST_FUSE_DAILY_CNY=1000
# 周成本上限（元）
COST_FUSE_WEEKLY_CNY=5000
# 触发熔断时的降级模型
COST_FUSE_DEGRADE_MODEL=claude-haiku-4-5
# 月成本上限（元）
COST_FUSE_MONTHLY_CNY=20000

# ============================================
# 实验设计参数
# ============================================

# 默认选择集数量
DEFAULT_N_CHOICE_SETS=12
# 每集选项数（不含None）
DEFAULT_N_ALTERNATIVES=3
# 默认样本量
DEFAULT_SAMPLE_SIZE=150
# D-efficiency 目标值
DEFAULT_D_EFFICIENCY_TARGET=0.85

# ============================================
# 真实性评分阈值
# ============================================

# 及格线
AUTHENTICITY_PASS_THRESHOLD=9
# 优秀线
AUTHENTICITY_EXCELLENT_THRESHOLD=12
# 最大分值
AUTHENTICITY_MAX_SCORE=14

# ============================================
# 偏见审计配置
# ============================================

# KS检验 p值阈值
BIAS_KS_P_THRESHOLD=0.05
# Cramér's V 阈值
BIAS_CRAMERS_V_THRESHOLD=0.1
# 香农熵归一化阈值
BIAS_ENTROPY_THRESHOLD=0.7

# ============================================
# 前端登录配置
# ============================================

# 使用 scripts/generate_password_hash.py 生成 bcrypt 哈希
FRONTEND_RESEARCHER_PASSWORD_HASH=
FRONTEND_ADMIN_PASSWORD_HASH=
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ============================================
# 监控配置
# ============================================

# Prometheus 指标暴露路径
METRICS_PATH=/metrics
# 慢请求阈值（秒）
SLOW_REQUEST_THRESHOLD=2.0
USE_REDIS_CACHE=false
DASHBOARD_CACHE_TTL=30
API_GRACEFUL_SHUTDOWN_TIMEOUT=30
